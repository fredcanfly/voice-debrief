[Unit]
Description=Voice Debrief FastAPI Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/voice-debrief
EnvironmentFile=/home/ubuntu/voice-debrief/.env
ExecStart=/home/ubuntu/voice-debrief/.venv/bin/uvicorn backend.app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
