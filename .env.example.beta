# ==============================
# BETA VARIABLES YOU WILL CHANGE
# ==============================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
PUBLIC_BASE_URL=https://your-backend-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-pwa-domain.example.com

# Optional: lock signup to specific emails later (comma-separated)
ALLOWED_EMAILS=

# ==============================
# APP MODE
# ==============================
APP_ENV=beta
MULTI_USER_MODE=true
BETA_SIGNUPS_OPEN=true
MAX_BETA_USERS=3
SUPABASE_JWT_AUDIENCE=authenticated

# ==============================
# SERVER
# ==============================
VOICE_DEBRIEF_HOST=0.0.0.0
VOICE_DEBRIEF_PORT=8787
DEBRIEF_OUTPUT_DIR=/mnt/c/Users/Trevis/Documents/Phone/debriefs

# ==============================
# HERMES / LLM
# ==============================
HERMES_API_BASE=http://127.0.0.1:8642/v1
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent

# ==============================
# STT / TTS
# ==============================
STT_PROVIDER=openai
OPENAI_API_KEY=YOUR_OPENAI_KEY
STT_MODEL=whisper-1
WHISPER_LANGUAGE=en
EDGE_TTS_VOICE=en-US-AriaNeural

# Endpoint defaults
WHISPER_VAD_MIN_SILENCE_MS=700
ENDPOINT_MIN_SPEECH_SECONDS=0.55
ENDPOINT_MIN_TEXT_CHARS=8

# Preset values (for setup UI)
DRIVING_MIN_SPEECH_SECONDS=0.75
DRIVING_MIN_TEXT_CHARS=12
DRIVING_VAD_SILENCE_MS=900
OFFICE_MIN_SPEECH_SECONDS=0.45
OFFICE_MIN_TEXT_CHARS=6
OFFICE_VAD_SILENCE_MS=600

# Cost guardrails
MONTHLY_STT_BUDGET_USD=10
SOFT_WARN_PCT_1=70
SOFT_WARN_PCT_2=90
HARD_STOP_ON_BUDGET=true
