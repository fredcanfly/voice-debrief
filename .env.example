# Voice Debrief Assistant — Pre-alpha config contract
# NOTE: Keep secrets out of git. Copy to `.env` for local values.

# App runtime
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8787
PUBLIC_BASE_URL=http://localhost:8787

# Storage
DATA_DIR=./data
SQLITE_DB_PATH=./data/voice_debrief.sqlite3
GENERATED_DOCS_DIR=./data/generated_docs
UPLOAD_DIR=./data/uploads

# LLM + STT provider (JIT setup at roadmap P1-03/P1-04)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini
STT_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# TTS provider switch (pre-alpha default = local Kokoro)
TTS_PROVIDER=kokoro
KOKORO_BASE_URL=http://127.0.0.1:8880
KOKORO_VOICE=af_sarah
KOKORO_FORMAT=wav

# Alternate TTS provider (future switch without code redesign)
# TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Hermes integration
HERMES_API_BASE=http://127.0.0.1:8642/v1
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent

# Conversational guardrails
MAX_FOLLOWUP_QUESTIONS=4
ASSISTANT_STYLE=concise
