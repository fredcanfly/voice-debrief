# Voice Debrief bridge
VOICE_DEBRIEF_HOST=0.0.0.0
VOICE_DEBRIEF_PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
DEBRIEF_OUTPUT_DIR=/mnt/c/Users/Trevis/Documents/Phone/debriefs

# Hermes API Server. Enable in ~/.hermes/.env with API_SERVER_ENABLED=true.
HERMES_API_BASE=http://127.0.0.1:8642/v1
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent

# Local STT
STT_PROVIDER=local
WHISPER_MODEL=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=en
WHISPER_VAD_MIN_SILENCE_MS=700
ENDPOINT_MIN_SPEECH_SECONDS=0.55
ENDPOINT_MIN_TEXT_CHARS=8

# Edge TTS
EDGE_TTS_VOICE=en-US-AriaNeural
